# ════════════════════════════════════════════════════════════════════════════
#  Video Note Extractor — Environment Configuration
#  Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ── Mode selection ────────────────────────────────────────────────────────────
# Leave GROQ_API_KEY empty to run fully locally with Ollama + local Whisper.
# Set it to use the free Groq cloud API instead (recommended for deployment).
#
# Free Groq key: https://console.groq.com  (no credit card required)
GROQ_API_KEY=

# ── Groq settings (only used when GROQ_API_KEY is set) ───────────────────────
# Available models: llama-3.1-8b-instant | llama-3.3-70b-versatile |
#                   mixtral-8x7b-32768   | gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ── Ollama settings (only used when GROQ_API_KEY is NOT set) ─────────────────
# Install: brew install ollama  |  curl -fsSL https://ollama.com/install.sh | sh
# Start:   ollama serve
# Models:  ollama pull llama3.2       ← 3B params, ~2 GB, fast
#          ollama pull mistral         ← 7B params, ~4 GB, better quality
#          ollama pull llama3.1:8b     ← 8B params, ~5 GB, best quality
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Local Whisper (only used when GROQ_API_KEY is NOT set) ───────────────────
# tiny | base | small | medium | large-v3
# RAM needed: base ~1 GB | small ~2 GB | medium ~5 GB | large-v3 ~10 GB
WHISPER_MODEL=base

# ── Embeddings (local mode only, sentence-transformers) ───────────────────────
EMBED_MODEL=all-MiniLM-L6-v2

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
AUDIO_DIR=./data/audio
CHROMA_PERSIST_DIR=./data/chroma

# ── RAG tuning (local mode) ───────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=5

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:8501
